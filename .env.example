# ============================================================================
# Claude Code MCP Server 配置文件
# ============================================================================

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 模块启用/禁用配置 (true/false)
# 默认启用: Claude Meta, Academic
# 默认禁用: Vision, GraphRAG, Audio

# Claude Meta - 会话管理、记忆、恢复
ENABLE_CLAUDE_META=true

# Academic - 论文搜索、引用验证 (Semantic Scholar)
ENABLE_ACADEMIC=true

# Vision - 图像分析、OCR、对象检测 (需要 API Key)
ENABLE_VISION=false

# GraphRAG - 知识图谱构建与问答
ENABLE_GRAPHRAG=false

# Audio - 文本转语音
ENABLE_AUDIO=false
